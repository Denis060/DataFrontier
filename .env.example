# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection, for `npm run db:push`. Full schema access —
# percent-encode any reserved characters in the password (@ becomes %40).
SUPABASE_DB_URL=

# Personal access token, for `npm run db:types`.
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Resend — transactional + newsletter email
RESEND_API_KEY=
RESEND_FROM_EMAIL=newsletter@thedatafrontier.com

# Public origin, used for OAuth redirects and canonical URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
